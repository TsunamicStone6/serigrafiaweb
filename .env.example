# ─── Sanity CMS ───────────────────────────────────────────────────────────────
# Obtén estos valores en: https://www.sanity.io/manage
NEXT_PUBLIC_SANITY_PROJECT_ID=tu_project_id_aqui
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01

# Token de escritura (solo necesario para el script de seed inicial)
# Crea uno en: sanity.io/manage → tu proyecto → API → Tokens
# IMPORTANTE: No subas este token al repo ni lo compartas
SANITY_API_TOKEN=tu_token_aqui
